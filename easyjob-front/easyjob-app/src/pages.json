{
	"easycom": {
		"autoscan": true,
		"custom": {
			// uni-ui 规则如下配置
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/Index",
			"style": {
				"navigationStyle": "custom"
				// 去掉默认title,"navigationBarTitleText": "uni-app",默认标题无法自定义操作
				// 设置上面行首行与模拟器状态栏重合
				// 浏览器无状态栏,置顶显示
				// 标题栏要自定义,实现导航、搜索等部分操作，自定义部分在stores
			}
		},
		{
			"path": "pages/question/QuestionIndex",
