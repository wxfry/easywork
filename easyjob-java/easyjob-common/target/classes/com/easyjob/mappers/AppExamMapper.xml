        <include refid="column_list_2"/>
        from app_text
        where chapter=#{chapter} and category_name=#{categoryName}
        order by create_time desc
        limit 1
    </select>

    <!-- 获取用户最后5次已完成考试的exam_id -->
    <select id="selectLastFiveCompletedExams" resultType="java.lang.Integer">
        SELECT exam_id
        FROM app_exam
        WHERE user_id = #{userId}
          AND status = 1
        ORDER BY create_time DESC
        LIMIT 5
    </select>

