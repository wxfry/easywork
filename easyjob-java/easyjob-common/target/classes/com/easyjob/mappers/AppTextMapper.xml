<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easyjob.mappers.AppTextMapper">

    <!--实体映射-->
    <resultMap id="base_result_map" type="com.easyjob.entity.po.AppText">
        <id column="text_id" property="textId"/>
        <result column="user_id" property="userId"/>
        <result column="nick_name" property="nickName"/>
        <result column="chapter" property="chapter"/>
        <result column="category_name" property="categoryName"/>
        <result column="create_time" property="createTime"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <resultMap id="question_result_map" type="com.easyjob.entity.po.AppTextQuestion">
        <!--自增ID-->
        <id column="id" property="id"/>
        <!--练习ID-->
        <result column="text_id" property="textId"/>
        <!--用户ID-->
        <result column="user_id" property="userId"/>
        <!--问题ID-->
        <result column="question_id" property="questionId"/>
        <!--章节-->
        <result column="chapter" property="chapter"/>
        <!--分类名称-->
        <result column="category_name" property="categoryName"/>
        <!--用户答案-->
        <result column="user_answer" property="userAnswer"/>
        <!--0:未作答 1:正确  2:错误-->
        <result column="answer_result" property="answerResult"/>
        <!--知识点-->
        <result column="knowledgePoint" property="knowledgePoint"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="base_column_list">
        text_id
        ,user_id,nick_name,chapter,category_name,create_time,start_time,end_time,status,remark
    </sql>
    <sql id="base_condition_filed">
        <if test="query.textId != null">
            and text_id = #{query.textId}
        </if>
        <if test="query.userId != null and query.userId!=''">
            and user_id = #{query.userId}
        </if>
        <if test="query.nickName != null and query.nickName!=''">
            and nick_name = #{query.nickName}
        </if>
        <if test="query.chapter != null and query.chapter!=''">
            and chapter = #{chapter}
        </if>
        <if test="query.categoryName != null and query.categoryName!=''">
            and category_name = #{query.categoryName}
        </if>
        <if test="query.createTime != null and query.createTime!=''">
            <![CDATA[ and  create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
        </if>
        <if test="query.startTime != null and query.startTime!=''">
            <![CDATA[ and  start_time=str_to_date(#{query.startTime}, '%Y-%m-%d') ]]>
        </if>
        <if test="query.endTime != null and query.endTime!=''">
            <![CDATA[ and  end_time=str_to_date(#{query.endTime}, '%Y-%m-%d') ]]>
        </if>
        <if test="query.status != null">
            and status = #{query.status}
        </if>
        <if test="query.remark != null and query.remark!=''">
            and remark = #{query.remark}
        </if>
    </sql>

    <sql id="question_column_list">
        id
        ,text_id,user_id,chapter,category_name,question_id,user_answer,
		 answer_result,knowledgePoint
    </sql>
    <sql id="base_condition_filed2">
        <if test="query.id != null">
            and id = #{query.id}
        </if>
        <if test="query.textId != null">
            and text_id = #{query.textId}
        </if>
        <if test="query.userId != null and query.userId!=''">
            and user_id = #{query.userId}
        </if>
        <if test="query.questionId != null">
            and question_id = #{query.questionId}
        </if>
        <if test="query.chapter != null">
            and chapter = #{query.chapter}
        </if>
        <if test="query.categoryName != null">
            and category_name = #{query.categoryName}
        </if>
        <if test="query.userAnswer != null and query.userAnswer!=''">
            and user_answer = #{query.userAnswer}
        </if>
        <if test="query.answerResult != null">
            and answer_result = #{query.answerResult}
        </if>
        <if test="query.knowledgePoint != null and query.knowledgePoint!=''">
            and knowledgePoint = #{query.knowledgePoint}
        </if>
    </sql>

    <!-- 通用查询条件列-->
    <sql id="query_condition">
        <where>
            <include refid="base_condition_filed"/>
            <if test="query.userIdFuzzy!= null  and query.userIdFuzzy!=''">
                and user_id like concat('%', #{query.userIdFuzzy}, '%')
            </if>
            <if test="query.nickNameFuzzy!= null  and query.nickNameFuzzy!=''">
                and nick_name like concat('%', #{query.nickNameFuzzy}, '%')
            </if>
            <if test="query.createTimeStart!= null and query.createTimeStart!=''">
                <![CDATA[ and  create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
            </if>
            <if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
                <![CDATA[ and  create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
            </if>
            <if test="query.startTimeStart!= null and query.startTimeStart!=''">
                <![CDATA[ and  start_time>=str_to_date(#{query.startTimeStart}, '%Y-%m-%d') ]]>
            </if>
            <if test="query.startTimeEnd!= null and query.startTimeEnd!=''">
                <![CDATA[ and  start_time< date_sub(str_to_date(#{query.startTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
            </if>
            <if test="query.endTimeStart!= null and query.endTimeStart!=''">
                <![CDATA[ and  end_time>=str_to_date(#{query.endTimeStart}, '%Y-%m-%d') ]]>
            </if>
            <if test="query.endTimeEnd!= null and query.endTimeEnd!=''">
                <![CDATA[ and  end_time< date_sub(str_to_date(#{query.endTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
            </if>
            <if test="query.remarkFuzzy!= null  and query.remarkFuzzy!=''">
                and remark like concat('%', #{query.remarkFuzzy}, '%')
            </if>
        </where>
    </sql>
    <sql id="query_condition2">
        <where>
            <include refid="base_condition_filed2"/>
            <if test="query.userIdFuzzy!= null  and query.userIdFuzzy!=''">
                and user_id like concat('%', #{query.userIdFuzzy}, '%')
            </if>
            <if test="query.userAnswerFuzzy!= null  and query.userAnswerFuzzy!=''">
                and user_answer like concat('%', #{query.userAnswerFuzzy}, '%')
            </if>
            <if test="query.questionIds!=null and query.questionIds.size()>0">
                and question_id in(<foreach collection="query.questionIds" separator="," item="item">#{item}</foreach>)
            </if>
            <if test="query.knowledgePoint != null">
                and knowledgePoint = #{query.knowledgePoint}
            </if>
            <if test="query.postTime!= null and query.postTime!=''">
                <![CDATA[ and  post_time>= date_sub(str_to_date(#{query.postTime}, '%Y-%m-%d'),interval -2 day)  ]]>
            </if>
        </where>
    </sql>

    <!-- 多条件修改 -->
    <update id="updateByParam" parameterType="com.easyjob.entity.query.AppTextQuery">
        UPDATE app_text
        <set>
            <if test="bean.userId != null">
                user_id = #{bean.userId},
            </if>
            <if test="bean.nickName != null">
                nick_name = #{bean.nickName},
            </if>
            <if test="bean.createTime != null">
                create_time = #{bean.createTime},
            </if>
            <if test="bean.chapter != null">
                chapter = #{bean.chapter},
            </if>
            <if test="bean.categoryName != null">
                category_name = #{bean.categoryName},
            </if>
            <if test="bean.startTime != null">
                start_time = #{bean.startTime},
            </if>
            <if test="bean.endTime != null">
                end_time = #{bean.endTime},
            </if>
            <if test="bean.status != null">
                status = #{bean.status},
            </if>
            <if test="bean.remark != null">
                remark = #{bean.remark},
            </if>
        </set>
        <include refid="query_condition"/>
    </update>

    <!--查询数量-->
    <select id="selectCount" resultType="java.lang.Integer">
        SELECT count(1)
        FROM app_text
        <include refid="query_condition"/>
    </select>

    <!-- 批量新增修改（批量插入） -->
    <insert id="insertOrUpdateBatch2" parameterType="com.easyjob.entity.po.AppTextQuestion">
        INSERT INTO app_text_question(
        text_id,
        user_id,
        question_id,
        chapter,
        category_name,
        user_answer,
        answer_result,
        knowledgePoint
        )values
        <foreach collection="list" item="item" separator=",">
            (#{item.textId},
            #{item.userId},
            #{item.questionId},
            #{item.chapter},
            #{item.categoryName},
            #{item.userAnswer},
            #{item.answerResult},
            #{item.knowledgePoint}
            )
        </foreach>
        on DUPLICATE key update
        text_id = VALUES(text_id),
        user_id = VALUES(user_id),
        question_id = VALUES(question_id),
        chapter = VALUES(chapter),
        category_name = VALUES(category_name),
        user_answer = VALUES(user_answer),
        answer_result = VALUES(answer_result),
        knowledgePoint = VALUES(knowledgePoint)
    </insert>


    <select id="selectList" resultMap="base_result_map">
        SELECT
        <include refid="base_column_list"/>
        FROM app_text
        <include refid="query_condition"/>
        <if test="query.simplePage!=null">
            limit #{query.simplePage.start},#{query.simplePage.end}
        </if>
    </select>

    <!-- 根据PrimaryKey获取对象-->
    <select id="selectByTextId" resultMap="base_result_map">
        select
        <include refid="base_column_list"/>
        from app_text where text_id=#{textId}
    </select>

    <!-- 查询textQuestionList -->
    <select id="selectTextList" resultMap="question_result_map">
        SELECT
        <include refid="question_column_list"/>
        FROM app_text_question
        <include refid="query_condition2"/>
        <if test="query.orderBy!=null">
            order by ${query.orderBy}
        </if>
        <if test="query.simplePage!=null">
            limit #{query.simplePage.start},#{query.simplePage.end}
        </if>
    </select>

    <insert id="insertOrUpdate2" parameterType="com.easyjob.entity.po.AppTextQuestion">
        INSERT INTO app_text_question
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="bean.textId != null">
                text_id,
            </if>
            <if test="bean.userId != null">
                user_id,
            </if>
            <if test="bean.questionId != null">
                question_id,
            </if>
            <if test="bean.chapter != null">
                chapter,
            </if>
            <if test="bean.categoryName != null">
                category_name,
            </if>
            <if test="bean.userAnswer != null">
                user_answer,
            </if>
            <if test="bean.answerResult != null">
                answer_result,
            </if>
            <if test="bean.knowledgePoint != null">
                knowledgePoint,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="bean.textId != null">
                #{bean.textId},
            </if>
            <if test="bean.userId != null">
                #{bean.userId},
            </if>
            <if test="bean.questionId != null">
                #{bean.questionId},
            </if>
            <if test="bean.chapter != null">
                #{bean.chapter},
            </if>
            <if test="bean.categoryName != null">
                #{bean.categoryName},
            </if>
            <if test="bean.userAnswer != null">
                #{bean.userAnswer},
            </if>
            <if test="bean.answerResult != null">
                #{bean.answerResult},
            </if>
            <if test="bean.knowledgePoint != null">
                #{bean.knowledgePoint},
            </if>
        </trim>
        on DUPLICATE key update
        <trim prefix="" suffix="" suffixOverrides=",">
            <if test="bean.textId != null">
                text_id = VALUES(text_id),
            </if>
            <if test="bean.userId != null">
                user_id = VALUES(user_id),
            </if>
            <if test="bean.questionId != null">
                question_id = VALUES(question_id),
            </if>
            <if test="bean.chapter != null">
                chapter = VALUES(chapter),
            </if>
            <if test="bean.categoryName != null">
                category_name = VALUES(category_name),
            </if>
            <if test="bean.userAnswer != null">
                user_answer = VALUES(user_answer),
            </if>
            <if test="bean.answerResult != null">
                answer_result = VALUES(answer_result),
            </if>
            <if test="bean.knowledgePoint != null">
                knowledgePoint = VALUES(knowledgePoint),
            </if>
        </trim>
    </insert>

    <select id="getTextAnswerResult" resultType="java.lang.Integer">
        select answer_result
        from app_text_question
        where text_id = #{textId}
          and question_id = #{questionId}
    </select>

    <select id="selectTextQuestion" resultMap="question_result_map">
        SELECT
        <include refid="question_column_list"/>
        FROM app_text_question
        <include refid="query_condition2"/>
    </select>

    <select id="selectByTextQuestion" resultMap="question_result_map">
        select
        <include refid="question_column_list"/>
        from app_text_question
        where text_id = #{textId}
        and question_id = #{questionId}
    </select>

    <select id="selectQuestion" resultType="com.easyjob.entity.po.ExamQuestion">
        select *
        from exam_question
        where question_id = #{questionId}
    </select>

    <select id="selectData" resultType="java.lang.Integer">
        SELECT count(1) FROM app_text_question
        <include refid="query_condition2"/>
    </select>

    <select id="selectDataByKnowledgePoint" resultType="java.lang.Integer">
        SELECT count(1) FROM app_text_question
        <where>
            <if test="query.userId != null and query.userId != ''">
                and user_id = #{query.userId}
            </if>
            <if test="query.knowledgePoint != null and query.knowledgePoint != ''">
                and knowledgePoint = #{query.knowledgePoint}
            </if>
        </where>
    </select>

    <select id="selectAllTextList" parameterType="map" resultMap="question_result_map">
        SELECT
        <include refid="question_column_list"/>
        FROM app_text_question
        where answer_result != 0

    </select>
    <select id="selectQuestionsByUserId" resultMap="question_result_map">
        select
        <include refid="question_column_list"/>
        from app_text_question
        where user_id = #{similarUserId}
        and answer_result = 1
    </select>
    <select id="selectQuestionsByUserIdAndKnowledgePoint" resultMap="question_result_map">
        select
        <include refid="question_column_list"/>
        from app_text_question
        where user_id = #{similarUserId}
        and knowledgePoint = #{knowledgePoint}
        and answer_result = 1
    </select>
</mapper>