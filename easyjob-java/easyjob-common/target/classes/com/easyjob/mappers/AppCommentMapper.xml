<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easyjob.mappers.AppCommentMapper">
    <!--        <select id="listRelate" resultType="com.easyjob.entity.dto.RelateDto">-->
    <!--            select *-->
    <!--            from relate-->
    <!--        </select>-->

    <!-- 关系表实体映射 -->
    <resultMap id="base_result_map" type="com.easyjob.entity.po.UserRelate">
        <result property="userId" column="user_id"/>
        <result property="questionId" column="question_id"/>
        <result property="times" column="times"/>
    </resultMap>

    <sql id="base_column_list">
        user_id
        ,question_id,times
    </sql>

    <select id="listRelate" resultMap="base_result_map">
        select
        <include refid="base_column_list"/>
        from relate
    </select>


    <sql id="question_column_list">
        question_id
        ,title,teacher,chapter,origin,knowledge_points,category_id,category_name,question_type,difficulty_level,question,question_answer,answer_analysis,status,create_time,create_user_id,create_user_name,post_user_type
    </sql>

    <resultMap id="question_result_map" type="com.easyjob.entity.po.ExamQuestion">
        <result property="questionId" column="question_id"/>
        <result property="title" column="title"/>
        <result property="teacher" column="teacher"/>
        <result property="chapter" column="chapter"/>
        <result property="origin" column="origin"/>
        <result property="knowledgePoints" column="knowledge_points"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="questionType" column="question_type"/>
        <result property="difficultyLevel" column="difficulty_level"/>
        <result property="question" column="question"/>
        <result property="questionAnswer" column="question_answer"/>
        <result property="answerAnalysis" column="answer_analysis"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createUserName" column="create_user_name"/>
        <result property="postUserType" column="post_user_type"/>
    </resultMap>

    <select id="selectCommendQuestion" resultMap="question_result_map">
        select
        <include refid="question_column_list"/>
        form exam_question where question_id = #{questionId} and status = 1
    </select>

    <update id="updateSign" parameterType="com.easyjob.entity.po.AppUserInfo">
        UPDATE app_user_info
        SET sign_date = #{date}
        WHERE user_id = #{userId}
    </update>

    <update id="updateAmount" parameterType="com.easyjob.entity.po.AppUserInfo">
        UPDATE app_user_info
        SET amount = #{signCount}
        WHERE user_id = #{userId}
    </update>

    <select id="selectAmount" parameterType="com.easyjob.entity.po.AppUserInfo" resultType="java.lang.Integer">
        SELECT amount
        FROM app_user_info
        WHERE user_id = #{userId}
    </select>

    <update id="updateScore" parameterType="com.easyjob.entity.po.AppUserInfo">
        UPDATE app_user_info
        SET score = score + 10
        WHERE user_id = #{userId}
    </update>
</mapper>